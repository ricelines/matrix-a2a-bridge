{
  manifest_version: "0.1.0",
  program: {
    image: "ghcr.io/ricelines/onboarding-agent",
    entrypoint: ["/app/mock-a2a", "--listen", ":8080"],
    network: {
      endpoints: [{ name: "a2a", port: 8080, protocol: "http" }],
    },
  },
  provides: {
    a2a: { kind: "a2a", endpoint: "a2a" },
  },
  exports: { a2a: "a2a" },
}
