{
  manifest_version: "0.3.0",
  config_schema: {
    type: "object",
    properties: {
      auth_json: { type: "string", secret: true },
      matrix_username: { type: "string" },
      matrix_password: { type: "string", secret: true },
      bot_session_idle_timeout: { type: "string", default: "10m" },
    },
    required: ["matrix_username", "matrix_password"],
    additionalProperties: false,
  },
  slots: {
    matrix: { kind: "http" },
  },
  components: {
    codex_agent: {
      manifest: "https://raw.githubusercontent.com/ricelines/codex-a2a/refs/heads/main/amber.json5",
      config: {
        auth_json: "${config.auth_json}",
        model: "gpt-5.4",
        model_reasoning_effort: "low",
      },
    },
    onboarding_agent: {
      manifest: "./onboarding-agent.json5",
      config: {
        matrix_username: "${config.matrix_username}",
        matrix_password: "${config.matrix_password}",
        bot_session_idle_timeout: "${config.bot_session_idle_timeout}",
      },
    },
  },
  bindings: [
    { to: "#onboarding_agent.matrix", from: "self.matrix", weak: true },
    { to: "#onboarding_agent.upstream_a2a", from: "#codex_agent.a2a" },
  ],
}
