{
  manifest_version: "0.1.0",
  slots: {
    matrix: { kind: "http" },
  },
  components: {
    mock_upstream: "./mock-a2a.json5",
    matrix_a2a_bridge: {
      manifest: "./matrix-a2a-bridge.json5",
      config: {
        matrix_username: "bot",
        matrix_password: "bot-password",
        bot_session_idle_timeout: "2s",
      },
    },
  },
  bindings: [
    { to: "#matrix_a2a_bridge.matrix", from: "self.matrix", weak: true },
    { to: "#matrix_a2a_bridge.upstream_a2a", from: "#mock_upstream.a2a" },
  ],
}
